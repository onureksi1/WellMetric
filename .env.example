# ──────────────────────────────────────────────
# WellAnalytics — Environment Variables Template
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# ── App ────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# ── PostgreSQL ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wellanalytics
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wellanalytics_db

# Full DSN (used by TypeORM / Prisma)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Full URL (used by BullMQ / ioredis)
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ── JWT ────────────────────────────────────────
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── File Storage (AWS S3 / Cloudflare R2) ──────
S3_BUCKET=wellanalytics-uploads
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=                # Leave empty for AWS; set for R2: https://<account>.r2.cloudflarestorage.com

# ── Email (Resend) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=noreply@wellanalytics.io

# ── AI (Anthropic Claude) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Frontend (Next.js public vars — prefix with NEXT_PUBLIC_) ──
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
