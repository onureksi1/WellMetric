{
  "name": "@wellanalytics/api",
  "version": "0.1.0",
  "private": true,
  "description": "WellAnalytics NestJS REST API",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npm run typeorm -- -d src/database/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- -d src/database/data-source.ts migration:revert",
    "migration:show": "npm run typeorm -- -d src/database/data-source.ts migration:show",
    "migration:generate": "npm run typeorm -- -d src/database/data-source.ts migration:generate src/database/migrations/",
    "reset:bruteforce": "node scripts/reset-brute-force.js",
    "reset:bruteforce:all": "node scripts/reset-brute-force.js all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-ses": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.1",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "bullmq": "^5.76.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "ioredis": "^5.3.2",
    "iyzipay": "^2.0.67",
    "nodemailer": "^8.0.7",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cron": "^2.0.1",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
